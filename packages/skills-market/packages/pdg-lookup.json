{
  "package_id": "pdg-lookup",
  "package_type": "skill-pack",
  "repo": "nullius/skills-market",
  "channel": "beta",
  "version": "0.1.0",
  "summary": "PDG local database lookup workflow skill.",
  "platforms": [
    "claude_code",
    "codex",
    "opencode"
  ],
  "source_path": "skills/pdg-lookup/SKILL.md",
  "install": {
    "claude_code": "Link into ~/.claude/skills or install via marketplace when available.",
    "codex": "Link into ~/.codex/skills for Codex native discovery.",
    "opencode": "Link into ~/.config/opencode/skills for OpenCode discovery."
  },
  "depends_on": {
    "hep-mcp": ">=0.4.0 <0.5.0"
  },
  "source": {
    "repo": "nullius/skills",
    "ref": "main",
    "subpath": "skills/pdg-lookup",
    "include": [
      "SKILL.md",
      "SKILL.zh.md",
      "README.md",
      "RUNBOOK.md",
      "ROADMAP.md",
      "PROJECT_MAP.md",
      "scripts/**",
      "assets/**",
      "references/**",
      "templates/**",
      "schemas/**",
      "agents/**",
      ".gitignore"
    ],
    "exclude": [
      "**/tests/**",
      "**/test/**",
      "**/tmp/**",
      "**/.pytest_cache/**",
      "**/__pycache__/**",
      "**/*.pyc",
      "**/.DS_Store",
      "team/*",
      "team/**/*",
      "process/*",
      "process/**/*",
      ".tmp*/*",
      ".tmp*/**/*"
    ]
  }
}
