{
  "package_id": "literature-graph-builder",
  "package_type": "skill-pack",
  "repo": "nullius/skills-market",
  "channel": "dev",
  "version": "0.1.0",
  "summary": "Build, validate, and QA portable literature graphs from deep-read notes, source-backed edges, rendered math, and figure assets.",
  "platforms": [
    "claude_code",
    "codex",
    "opencode"
  ],
  "source_path": "skills/literature-graph-builder/SKILL.md",
  "depends_on": {
    "claim-grounding": ">=0.1.0 <0.2.0",
    "deep-literature-review": ">=0.1.0 <0.2.0",
    "markdown-hygiene": ">=0.1.0 <0.2.0",
    "review-swarm": ">=0.1.0 <0.2.0"
  },
  "install": {
    "claude_code": "Link into ~/.claude/skills or install via marketplace when available.",
    "codex": "Link into ~/.codex/skills for Codex native discovery.",
    "opencode": "Link into ~/.config/opencode/skills for OpenCode discovery."
  },
  "source": {
    "repo": "nullius/skills",
    "ref": "main",
    "subpath": "skills/literature-graph-builder",
    "include": [
      "SKILL.md",
      "agents/**",
      "references/**",
      "scripts/**"
    ],
    "exclude": [
      "**/tests/**",
      "**/test/**",
      "**/tmp/**",
      "**/.pytest_cache/**",
      "**/__pycache__/**",
      "**/*.pyc",
      "**/.DS_Store"
    ]
  }
}
