{
  "name": "@autoresearch/hepdata-mcp",
  "version": "0.1.0",
  "description": "HEPData MCP server for experimental HEP measurement data",
  "author": "Feng-Kun Guo",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tooling": {
      "import": "./dist/tooling.js",
      "types": "./dist/tooling.d.ts"
    }
  },
  "bin": {
    "hepdata-mcp": "./bin/hepdata-mcp.js"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:eval": "echo \"(hepdata-mcp) no eval suite\"",
    "test:eval:update": "echo \"(hepdata-mcp) no eval snapshots\"",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@autoresearch/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "zod": "^4.3.5"
  },
  "peerDependencies": {
    "playwright": "^1.48.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "playwright": "^1.48.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.16"
  }
}
