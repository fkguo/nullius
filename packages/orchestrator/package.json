{
  "name": "@nullius/orchestrator",
  "version": "0.4.0",
  "private": true,
  "description": "Generic lifecycle control plane and bounded workflow CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nullius": "dist/cli.js"
  },
  "scripts": {
    "prebuild": "node ../../scripts/ensure-workspace-package-artifacts.mjs @nullius/shared @nullius/literature-workflows",
