{
  "recipe_id": "literature_landscape",
  "name": "Literature Landscape",
  "description": "Build a landscape and reading-list seed from atomic search, topic, network, and provenance operators.",
  "entry_tool": "literature_workflows.resolve",
  "steps": [
    {
      "id": "seed_search",
      "task_kind": "literature",
      "action": "discover.seed_search",
      "purpose": "Run a broad keyword search to seed the landscape",
      "required_capabilities": [
        "supports_keyword_search"
      ],
      "preferred_providers": [
        "inspire",
        "openalex",
        "arxiv"
      ],
      "degrade_mode": "fail_closed",
      "consumer_hints": {
        "phases": [
          "prework"
        ],
        "artifact": "seed_search",
        "search_depth_contract": {
          "mode": "deep",
          "default_page_size": 50,
          "default_page_size_semantics": "page_size_not_completion_threshold",
          "pagination_required": true,
          "cursor_or_page_tracking_required": true,
          "continuation_required": true,
          "returned_count_required": true,
          "stop_reason_required": true,
          "coverage_incomplete_status": "coverage_incomplete",
          "candidate_pool_artifact": "seed_search_candidates",
          "selection_rationale_required": true,
          "query_expansion_expected": true,
          "citation_expansion_expected": true
        },
        "literature_saturation_contract": {
          "artifact": "knowledge_base/methodology_traces/literature_saturation.json",
          "final_status_values": [
            "saturated",
            "coverage_incomplete"
          ],
          "saturated_required_for_completion": true,
          "coverage_incomplete_allowed_only_as_debt": true,
          "provider_coverage_required": true,
          "providers_expected": [
            "inspire",
            "arxiv",
            "openalex",
            "web"
          ],
          "candidate_pool_required": true,
          "candidate_disposition_ledger_required": true,
          "core_paper_references_required": true,
          "core_paper_citations_required": true,
          "bibliography_reconciliation_required": true,
          "stable_identity_resolution_required": true,
          "unresolved_candidates_are_coverage_debt": true,
          "method_family_audit_required": true,
          "method_description_evidence_required": true,
          "bounded_bibliography_traversal_required": true,
          "metadata_only_not_evidence_ready": true,
          "page_size_not_completion_threshold": true
        },
        "reading_handoff_contract": {
          "mode": "source_first",
          "source_preference": [
            "arxiv_latex_source",
            "full_text_pdf",
            "available_full_text",
            "metadata_only_not_evidence_ready"
          ],
          "note_upgrade_required": true,
          "expected_artifact": "source_first_reading_notes",
          "locators_required": true,
          "key_equations_required": true,
          "limitations_required": true
        }
      },
      "params": {
        "query": "<query>",
        "size": 50
      }
    },
    {
      "id": "topic_scan",
      "task_kind": "literature",
      "action": "analyze.topic_evolution",
      "purpose": "Summarize topic trends and emerging subtopics",
      "depends_on": [
        "seed_search"
      ],
      "required_capabilities": [
        "analysis.topic_evolution"
      ],
      "preferred_providers": [
        "inspire"
      ],
      "degrade_mode": "partial_result",
      "consumer_hints": {
        "phases": [
          "prework"
        ],
        "artifact": "topic_analysis"
      },
      "params": {
        "mode": "timeline",
        "topic": "<topic>",
        "limit": 20
      }
    },
    {
      "id": "citation_network",
      "task_kind": "finding",
      "action": "analyze.citation_network",
      "purpose": "Map the citation structure around an anchor paper",
      "depends_on": [
        "seed_search"
      ],
      "required_capabilities": [
        "analysis.citation_network"
      ],
      "preferred_providers": [
        "inspire"
      ],
      "degrade_mode": "partial_result",
      "consumer_hints": {
        "phases": [
          "prework"
        ],
        "artifact": "network_analysis",
        "literature_saturation_contract": {
          "artifact": "knowledge_base/methodology_traces/literature_saturation.json",
          "final_status_values": [
            "saturated",
            "coverage_incomplete"
          ],
          "saturated_required_for_completion": true,
          "coverage_incomplete_allowed_only_as_debt": true,
          "provider_coverage_required": true,
          "providers_expected": [
            "inspire",
            "arxiv",
            "openalex",
            "web"
          ],
          "candidate_pool_required": true,
          "candidate_disposition_ledger_required": true,
          "core_paper_references_required": true,
          "core_paper_citations_required": true,
          "bibliography_reconciliation_required": true,
          "stable_identity_resolution_required": true,
          "unresolved_candidates_are_coverage_debt": true,
          "method_family_audit_required": true,
          "method_description_evidence_required": true,
          "bounded_bibliography_traversal_required": true,
          "metadata_only_not_evidence_ready": true,
          "page_size_not_completion_threshold": true
        }
      },
      "params": {
        "mode": "citation",
        "seed": "<seed_recid>",
        "limit": 50
      }
    },
    {
      "id": "source_trace",
      "task_kind": "evidence_search",
      "action": "analyze.provenance_trace",
      "purpose": "Trace likely original sources for a representative anchor paper",
      "depends_on": [
        "citation_network"
      ],
      "required_capabilities": [
        "analysis.provenance_trace"
      ],
      "preferred_providers": [
        "inspire"
      ],
      "degrade_mode": "partial_result",
      "consumer_hints": {
        "phases": [
          "prework"
        ],
        "artifact": "source_trace"
      },
      "params": {
        "recid": "<seed_recid>",
        "max_depth": 2,
        "max_refs_per_level": 20
      }
    }
  ]
}
