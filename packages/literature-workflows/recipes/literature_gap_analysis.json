{
  "recipe_id": "literature_gap_analysis",
  "name": "Literature Gap Analysis",
  "description": "Probe a paper set for tensions, omissions, and open seams using bounded atomic analysis operators.",
  "entry_tool": "literature_workflows.resolve",
  "steps": [
    {
      "id": "seed_search",
      "task_kind": "literature",
      "action": "discover.seed_search",
      "purpose": "Run a search to assemble the initial paper set",
      "required_capabilities": [
        "supports_keyword_search"
      ],
      "preferred_providers": [
        "inspire",
        "openalex",
        "arxiv"
      ],
      "degrade_mode": "fail_closed",
      "consumer_hints": {
        "phases": [
          "discover"
        ],
        "artifact": "seed_search",
        "search_depth_contract": {
          "mode": "deep",
          "default_page_size": 50,
          "default_page_size_semantics": "page_size_not_completion_threshold",
          "pagination_required": true,
          "cursor_or_page_tracking_required": true,
          "continuation_required": true,
          "returned_count_required": true,
          "stop_reason_required": true,
          "coverage_incomplete_status": "coverage_incomplete",
          "candidate_pool_artifact": "seed_search_candidates",
          "selection_rationale_required": true,
          "query_expansion_expected": true,
          "citation_expansion_expected": true
        },
        "literature_saturation_contract": {
          "artifact": "knowledge_base/methodology_traces/literature_saturation.json",
          "final_status_values": [
            "saturated",
            "coverage_incomplete"
          ],
          "saturated_required_for_completion": true,
          "coverage_incomplete_allowed_only_as_debt": true,
          "provider_coverage_required": true,
          "providers_expected": [
            "inspire",
            "arxiv",
            "openalex",
            "web"
          ],
          "candidate_pool_required": true,
          "candidate_disposition_ledger_required": true,
          "core_paper_references_required": true,
          "core_paper_citations_required": true,
          "bibliography_reconciliation_required": true,
          "stable_identity_resolution_required": true,
          "unresolved_candidates_are_coverage_debt": true,
          "method_family_audit_required": true,
          "method_description_evidence_required": true,
          "bounded_bibliography_traversal_required": true,
          "metadata_only_not_evidence_ready": true,
          "page_size_not_completion_threshold": true
        },
        "reading_handoff_contract": {
          "mode": "source_first",
          "source_preference": [
            "arxiv_latex_source",
            "full_text_pdf",
            "available_full_text",
            "metadata_only_not_evidence_ready"
          ],
          "note_upgrade_required": true,
          "expected_artifact": "source_first_reading_notes",
          "locators_required": true,
          "key_equations_required": true,
          "limitations_required": true
        }
      },
      "params": {
        "query": "<query>",
        "size": 50
      }
    },
    {
      "id": "topic_scan",
      "task_kind": "literature",
      "action": "analyze.topic_evolution",
      "purpose": "Summarize trends and identify underexplored subtopics",
      "depends_on": [
        "seed_search"
      ],
      "required_capabilities": [
        "analysis.topic_evolution"
      ],
      "preferred_providers": [
        "inspire"
      ],
      "degrade_mode": "fail_closed",
      "consumer_hints": {
        "phases": [
          "analyze"
        ],
        "artifact": "topic_analysis"
      },
      "params": {
        "mode": "timeline",
        "topic": "<topic>",
        "limit": 20
      }
    },
    {
      "id": "critical_analysis",
      "task_kind": "review",
      "action": "analyze.paper_set_critical_review",
      "purpose": "Run bounded critical analysis over representative papers",
      "depends_on": [
        "topic_scan"
      ],
      "required_capabilities": [
        "analysis.paper_set_critical_review"
      ],
      "preferred_providers": [
        "inspire"
      ],
      "degrade_mode": "fail_closed",
      "consumer_hints": {
        "phases": [
          "analyze"
        ],
        "artifact": "critical_analysis"
      },
      "params": {
        "recid": "<analysis_seed>"
      }
    },
    {
      "id": "citation_network",
      "task_kind": "finding",
      "action": "analyze.citation_network",
      "purpose": "Map citation structure around the current anchor paper",
      "depends_on": [
        "critical_analysis"
      ],
      "required_capabilities": [
        "analysis.citation_network"
      ],
      "preferred_providers": [
        "inspire"
      ],
      "degrade_mode": "fail_closed",
      "consumer_hints": {
        "phases": [
          "analyze"
        ],
        "artifact": "network_analysis",
        "literature_saturation_contract": {
          "artifact": "knowledge_base/methodology_traces/literature_saturation.json",
          "final_status_values": [
            "saturated",
            "coverage_incomplete"
          ],
          "saturated_required_for_completion": true,
          "coverage_incomplete_allowed_only_as_debt": true,
          "provider_coverage_required": true,
          "providers_expected": [
            "inspire",
            "arxiv",
            "openalex",
            "web"
          ],
          "candidate_pool_required": true,
          "candidate_disposition_ledger_required": true,
          "core_paper_references_required": true,
          "core_paper_citations_required": true,
          "bibliography_reconciliation_required": true,
          "stable_identity_resolution_required": true,
          "unresolved_candidates_are_coverage_debt": true,
          "method_family_audit_required": true,
          "method_description_evidence_required": true,
          "bounded_bibliography_traversal_required": true,
          "metadata_only_not_evidence_ready": true,
          "page_size_not_completion_threshold": true
        }
      },
      "params": {
        "mode": "citation",
        "seed": "<analysis_seed>",
        "limit": 50
      }
    },
    {
      "id": "connection_scan",
      "task_kind": "finding",
      "action": "analyze.paper_connections",
      "purpose": "Detect bridge papers, isolated clusters, and external hubs",
      "depends_on": [
        "citation_network"
      ],
      "required_capabilities": [
        "analysis.paper_set_connections"
      ],
      "preferred_providers": [
        "inspire"
      ],
      "degrade_mode": "fail_closed",
      "consumer_hints": {
        "phases": [
          "analyze"
        ],
        "artifact": "connection_scan"
      },
      "params": {
        "recids": "<recids>",
        "include_external": true,
        "max_external_depth": 1
      }
    }
  ]
}
