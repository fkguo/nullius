{
  "name": "@nullius/literature-workflows",
  "version": "0.4.0",
  "description": "Checked-in literature workflow authority pack and provider/capability resolver",
  "author": "Feng-Kun Guo",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "prebuild": "node ../../scripts/ensure-workspace-package-artifacts.mjs @nullius/shared @nullius/arxiv-mcp @nullius/openalex-mcp",
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prelint": "node ../../scripts/ensure-workspace-package-artifacts.mjs @nullius/shared @nullius/arxiv-mcp @nullius/openalex-mcp",
    "lint": "tsc --noEmit",
    "pretest": "node ../../scripts/ensure-workspace-package-artifacts.mjs @nullius/shared @nullius/arxiv-mcp @nullius/openalex-mcp",
    "test": "vitest run"
  },
  "dependencies": {
    "@nullius/arxiv-mcp": "workspace:*",
    "@nullius/openalex-mcp": "workspace:*",
    "@nullius/shared": "workspace:*",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.16"
  }
}
