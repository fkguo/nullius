{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ranking_result_v1.schema.json",
  "title": "RankingResult v1",
  "description": "Result of rank.compute: nodes ordered by their externally computed belief posterior (descending; ties by evidence_count descending, then stable input order). Nodes excluded from the ordering are reported explicitly in skipped_nodes.",
  "type": "object",
  "required": ["campaign_id", "method", "generated_at", "ranked_nodes", "skipped_nodes", "budget_snapshot", "idempotency", "ranking_artifact_ref"],
  "properties": {
    "campaign_id": { "type": "string", "format": "uuid" },
    "method": { "const": "posterior" },
    "generated_at": { "type": "string", "format": "date-time" },
    "ranked_nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "idea_id", "rank", "posterior_value", "evidence_count"],
        "properties": {
          "node_id": { "type": "string", "format": "uuid" },
          "idea_id": { "type": "string", "format": "uuid" },
          "rank": { "type": "integer", "minimum": 1 },
          "posterior_value": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence_count": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      },
      "description": "May be empty when no node carries a posterior yet."
    },
    "skipped_nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "reason"],
        "properties": {
          "node_id": { "type": "string", "format": "uuid" },
          "reason": { "enum": ["no_posterior", "waiting_activation", "archived"] }
        },
        "additionalProperties": false
      },
      "description": "Nodes excluded from the ordering, reported explicitly instead of being silently dropped."
    },
    "budget_snapshot": { "$ref": "./budget_snapshot_v1.schema.json" },
    "idempotency": { "$ref": "./idempotency_meta_v1.schema.json" },
    "ranking_artifact_ref": { "type": "string", "format": "uri" }
  },
  "additionalProperties": false
}
