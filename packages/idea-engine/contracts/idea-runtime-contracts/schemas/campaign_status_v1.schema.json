{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "campaign_status_v1.schema.json",
  "title": "CampaignStatus v1",
  "description": "Campaign status returned by the engine. Exposes lifecycle status and budget for observability.",
  "type": "object",
  "required": [
    "campaign_id",
    "status",
    "budget_snapshot"
  ],
  "properties": {
    "campaign_id": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "enum": [
        "running",
        "paused",
        "early_stopped",
        "exhausted",
        "completed"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "early_stop_reason": {
      "type": "string",
      "description": "Optional machine-readable reason when status=early_stopped (policy halt rather than budget exhaustion)."
    },
    "budget_snapshot": {
      "$ref": "./budget_snapshot_v1.schema.json"
    },
    "node_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "early_stopped"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "early_stop_reason"
        ]
      }
    }
  ],
  "additionalProperties": false
}
