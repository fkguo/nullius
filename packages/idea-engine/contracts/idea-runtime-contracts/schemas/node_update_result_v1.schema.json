{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "node_update_result_v1.schema.json",
  "title": "NodeUpdateResult v1",
  "description": "Result of a side-effecting node mutation (node.set_posterior / node.set_lifecycle): updated node summary plus idempotency metadata and the current budget snapshot.",
  "type": "object",
  "required": [
    "campaign_id",
    "node",
    "budget_snapshot",
    "idempotency"
  ],
  "properties": {
    "campaign_id": {
      "type": "string",
      "pattern": "^[0123456789abcdefghjkmnpqrstvwxyz]{8}$"
    },
    "node": {
      "type": "object",
      "required": [
        "node_id",
        "idea_id",
        "revision",
        "lifecycle_state",
        "lifecycle_reason",
        "posterior",
        "activation_condition",
        "updated_at"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "pattern": "^[0123456789abcdefghjkmnpqrstvwxyz]{8}$"
        },
        "idea_id": {
          "type": "string",
          "pattern": "^[0123456789abcdefghjkmnpqrstvwxyz]{8}$"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "lifecycle_state": {
          "enum": [
            "candidate",
            "admission_review",
            "admitted",
            "needs_refresh",
            "admission_blocked",
            "waiting_activation",
            "archived"
          ]
        },
        "lifecycle_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "posterior": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "required": [
                "value",
                "evidence_count",
                "updated_at"
              ],
              "properties": {
                "value": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "evidence_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "updated_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "gaia_package_ref": {
                  "type": "string",
                  "format": "uri"
                },
                "status": {
                  "enum": [
                    "current",
                    "provisional",
                    "stale"
                  ]
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "literature_coverage": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "required": [
                "status"
              ],
              "properties": {
                "status": {
                  "enum": [
                    "saturated",
                    "coverage_incomplete",
                    "metadata_only"
                  ]
                },
                "survey_ref": {
                  "type": "string",
                  "minLength": 1
                },
                "close_prior_matrix_ref": {
                  "type": "string",
                  "minLength": 1
                },
                "exploratory_allocation": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false,
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "status": {
                        "enum": [
                          "saturated",
                          "coverage_incomplete"
                        ]
                      }
                    },
                    "required": [
                      "status"
                    ]
                  },
                  "then": {
                    "required": [
                      "survey_ref",
                      "close_prior_matrix_ref"
                    ]
                  }
                }
              ]
            }
          ]
        },
        "activation_condition": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "required": [
                "kind",
                "description",
                "satisfied"
              ],
              "properties": {
                "kind": {
                  "enum": [
                    "tool_readiness",
                    "data_release",
                    "stage_reached",
                    "exploratory_computation",
                    "required_evidence",
                    "other"
                  ]
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                },
                "satisfied": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "budget_snapshot": {
      "$ref": "./budget_snapshot_v1.schema.json"
    },
    "idempotency": {
      "$ref": "./idempotency_meta_v1.schema.json"
    }
  },
  "additionalProperties": false
}
