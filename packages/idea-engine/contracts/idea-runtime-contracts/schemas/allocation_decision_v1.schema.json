{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "allocation_decision_v1.schema.json",
  "title": "AllocationDecision v1",
  "description": "Record of one investment-allocation decision over the idea portfolio, produced by the decision layer via Thompson sampling from the node posteriors. Nodes in waiting_activation are listed separately with their activation conditions.",
  "type": "object",
  "required": [
    "decision_id",
    "campaign_id",
    "generated_at",
    "method",
    "random_seed",
    "candidates",
    "waiting_activation"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^[0123456789abcdefghjkmnpqrstvwxyz]{8}$"
    },
    "campaign_id": {
      "type": "string",
      "pattern": "^[0123456789abcdefghjkmnpqrstvwxyz]{8}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "method": {
      "const": "thompson_sampling"
    },
    "random_seed": {
      "type": "integer",
      "description": "Seed of the sampling draw, recorded so the decision is reproducible."
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "lifecycle_state",
          "posterior_value",
          "evidence_count",
          "sampled_value",
          "posterior_status",
          "literature_coverage_status",
          "allocation_eligible",
          "exploratory_allocation",
          "allocation",
          "budget_note"
        ],
        "properties": {
          "node_id": {
            "type": "string",
            "pattern": "^[0123456789abcdefghjkmnpqrstvwxyz]{8}$"
          },
          "lifecycle_state": {
            "enum": [
              "candidate",
              "admission_review",
              "admitted",
              "needs_refresh",
              "admission_blocked"
            ],
            "description": "The node's lifecycle state at allocation time. Only admitted nodes are sampled; waiting_activation nodes are listed in the waiting_activation array instead, and archived nodes are excluded."
          },
          "posterior_value": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1,
            "description": "Null for a cold-start candidate that has no belief-graph posterior yet."
          },
          "evidence_count": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "sampled_value": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1,
            "description": "The Thompson draw for this node in this decision round; null for a cold-start candidate."
          },
          "posterior_status": {
            "type": ["string", "null"],
            "enum": [
              "current",
              "provisional",
              "stale",
              null
            ],
            "description": "Current/provisional/stale status of the stored posterior. Null for cold-start candidates with no posterior."
          },
          "literature_coverage_status": {
            "enum": [
              "saturated",
              "coverage_incomplete",
              "metadata_only"
            ],
            "description": "Close-prior literature coverage status visible at allocation time. metadata_only means no source-first deep literature survey has been accepted yet."
          },
          "allocation_eligible": {
            "type": "boolean",
            "description": "False when the node is shown for portfolio triage but was not eligible for Thompson sampling, for example because close-prior literature coverage is incomplete."
          },
          "exploratory_allocation": {
            "type": "boolean",
            "description": "True only for an explicitly declared exploratory allocation over coverage_incomplete literature; ordinary coverage_incomplete nodes must not be allocation eligible."
          },
          "allocation": {
            "enum": [
              "deep_investment",
              "reconnaissance",
              "hold"
            ]
          },
          "budget_note": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "waiting_activation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "activation_condition",
          "last_checked_at"
        ],
        "properties": {
          "node_id": {
            "type": "string",
            "pattern": "^[0123456789abcdefghjkmnpqrstvwxyz]{8}$"
          },
          "activation_condition": {
            "type": "object",
            "required": [
              "kind",
              "description",
              "satisfied"
            ],
            "properties": {
              "kind": {
                "enum": [
                  "tool_readiness",
                  "data_release",
                  "stage_reached",
                  "exploratory_computation",
                  "other"
                ]
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "satisfied": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          },
          "last_checked_at": {
            "type": ["string", "null"],
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
