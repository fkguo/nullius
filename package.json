{
  "name": "nullius",
  "version": "0.5.0",
  "private": true,
  "description": "Nullius ecosystem monorepo — evidence-first theory-research substrate, control-plane, and provider packages",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "codegen": "bash meta/scripts/codegen.sh",
    "codegen:check": "bash meta/scripts/codegen.sh && git diff --exit-code -- packages/shared/src/generated meta/generated",
    "check:governance-sync": "node scripts/check-governance-sync.mjs",
    "check:atomic-write-anti-drift": "node scripts/check-atomic-write-anti-drift.mjs",
    "check:harness-invocation-anti-drift": "node scripts/check-harness-invocation-anti-drift.mjs",
    "check:integrity-receipt-anti-drift": "node scripts/check-integrity-receipt-anti-drift.mjs",
    "check:skill-tool-name-anti-drift": "node scripts/check-skill-tool-name-anti-drift.mjs",
    "check:portable-paths-anti-drift": "node scripts/check-portable-paths-anti-drift.mjs",
    "check:scaffold-authority": "node scripts/check-scaffold-authority.mjs",
    "check:host-neutral-skill-paths-anti-drift": "node scripts/check-host-neutral-skill-paths-anti-drift.mjs",
    "check:transcription-fidelity-checklist-anti-drift": "node scripts/check-transcription-fidelity-checklist-anti-drift.mjs",
    "check:launch-authorization-anti-drift": "node scripts/check-launch-authorization-anti-drift.mjs",
    "check:citation-identity-grounding-anti-drift": "node scripts/check-citation-identity-grounding-anti-drift.mjs",
    "check:literature-coverage-closure-anti-drift": "node scripts/check-literature-coverage-closure-anti-drift.mjs",
    "check:idea-posterior-reader-surface-anti-drift": "node scripts/check-idea-posterior-reader-surface-anti-drift.mjs",
    "check:reuse-or-deviate-anti-drift": "node scripts/check-reuse-or-deviate-anti-drift.mjs",
    "check:review-verification-contract-anti-drift": "node scripts/check-review-verification-contract-anti-drift.mjs"
  },
  "author": "Feng-Kun Guo",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.21.0"
  }
}
