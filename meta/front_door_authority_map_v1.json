{
  "version": 1,
  "note": "Classification and docs/tests consumption layer only. `nullius` stays the stateful CLI front door, `orch_*` stays the control-plane MCP/operator counterpart, and provider surfaces stay bounded atomic MCP operators. Exact inventories remain owned by their source surfaces and must be kept in sync by fail-closed tests.",
  "surfaces": {
    "nullius_cli": {
      "classification": "canonical_public",
      "surface_kind": "cli_command_inventory",
      "owner": "@nullius/orchestrator",
      "notes": [
        "Canonical stateful CLI front door for initialized external project roots.",
        "Owns lifecycle state, workflow-plan, bounded execution, verification, higher-conclusion gating, and proposal decisions."
      ],
      "exact_inventory_source": "packages/orchestrator/src/cli-command-inventory.ts",
      "commands": [
        {
          "command": "init",
          "usage": "nullius init [options]"
        },
        {
          "command": "run",
          "usage": "nullius run --workflow-id <id> [options]"
        },
        {
          "command": "verify",
          "usage": "nullius verify --run-id <id> --status <passed|failed|blocked> --summary \"...\" --evidence-path <path> [--evidence-path <path> ...]"
        },
        {
          "command": "final-conclusions",
          "usage": "nullius final-conclusions --run-id <id> [--note \"...\"]"
        },
        {
          "command": "proposal-decision",
          "usage": "nullius proposal-decision --proposal-kind <repair|skill|optimize|innovate> --proposal-id <id> --decision <accepted_for_later|dismissed|already_captured> [--note \"...\"]"
        },
        {
          "command": "status",
          "usage": "nullius status [--json]"
        },
        {
          "command": "approve",
          "usage": "nullius approve <approval_id> [--note \"...\"]"
        },
        {
          "command": "integrity-record",
          "usage": "nullius integrity-record --approval-id <id> --modes <M1[,M2,...]> --notes \"<summary>\" [--skip <Mx:reason>[,Mx:reason]...]"
        },
        {
          "command": "pause",
          "usage": "nullius pause [--note \"...\"]"
        },
        {
          "command": "resume",
          "usage": "nullius resume [--note \"...\"] [--force]"
        },
        {
          "command": "export",
          "usage": "nullius export [options]"
        },
        {
          "command": "workflow-plan",
          "usage": "nullius workflow-plan --recipe <recipe_id> [options]"
        },
        {
          "command": "graph",
          "usage": "nullius graph --kind <claims|progress|literature|roadmap> [--claims <path> --edges <path> | --plan <path> | --input <path> | --spec <path>] [--out-dir <dir>] [--format dot|png|svg] [--rank-dir LR|TB] [--legend auto|embedded|none] [--no-color] [--json]"
        }
      ]
    },
    "orchestrator_mcp_tools_spec": {
      "classification": "canonical_public",
      "surface_kind": "exact_doc_inventory",
      "owner": "@nullius/orchestrator",
      "notes": [
        "Canonical MCP/operator counterpart of the same control plane surfaced by `nullius`.",
        "Not a competing root product identity and not a provider-local workflow shell."
      ],
      "exact_inventory_source": "meta/docs/orchestrator-mcp-tools-spec.md",
      "live_registry_source": "packages/orchestrator/src/orch-tools/index.ts / @nullius/orchestrator exported ORCH_TOOL_SPECS",
      "drift_test_source": "packages/orchestrator/tests/orchestrator-mcp-tools-spec.test.ts",
      "namespace_families": [
        "orch_run_*",
        "orch_policy_*",
        "orch_fleet_*"
      ]
    },
    "idea_mcp": {
      "classification": "canonical_public",
      "surface_kind": "mcp_tool_inventory",
      "owner": "@nullius/idea-mcp",
      "notes": [
        "Experimental runtime bridge for idea campaign lifecycle management.",
        "Not a root front door and intentionally narrower than the full `idea-engine` runtime contract (node posterior/lifecycle/rank/promote methods stay engine-side)."
      ],
      "exact_inventory_source": "packages/idea-mcp/src/tool-registry.ts",
      "tools": [
        {
          "name": "idea_campaign_init",
          "rpc_method": "campaign.init"
        },
        {
          "name": "idea_campaign_status",
          "rpc_method": "campaign.status"
        },
        {
          "name": "idea_campaign_topup",
          "rpc_method": "campaign.topup"
        },
        {
          "name": "idea_campaign_pause",
          "rpc_method": "campaign.pause"
        },
        {
          "name": "idea_campaign_resume",
          "rpc_method": "campaign.resume"
        },
        {
          "name": "idea_campaign_complete",
          "rpc_method": "campaign.complete"
        }
      ]
    }
  }
}
