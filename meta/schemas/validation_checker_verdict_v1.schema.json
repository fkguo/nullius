{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nullius.dev/schemas/validation_checker_verdict_v1.schema.json",
  "title": "ValidationCheckerVerdict V1",
  "description": "Structured self-report emitted by a checker directly executed by Nullius. request_sha256 binds the report to the exact Nullius-generated request; matching observations do not by themselves prove that the checker actually read the output or executed the named negative controls.",
  "type": "object",
  "required": [
    "schema_version",
    "request_sha256",
    "check_kind",
    "status",
    "summary",
    "quantity_id",
    "layer_id",
    "disputed_dimensions",
    "consumed_output_observations",
    "negative_control_results"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "request_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "check_kind": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "blocked"]
    },
    "summary": { "type": "string", "minLength": 1 }
    ,"quantity_id": { "type": "string", "minLength": 1 }
    ,"layer_id": { "type": "string", "minLength": 1 }
    ,"disputed_dimensions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
    ,"consumed_output_observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["uri", "path", "sha256"],
        "properties": {
          "uri": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        },
        "additionalProperties": false
      }
    }
    ,"negative_control_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["control_id", "status"],
        "properties": {
          "control_id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pass", "fail", "blocked"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
