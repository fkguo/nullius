{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nullius.dev/schemas/research_loop_packet_v1.schema.json",
  "title": "ResearchLoopPacket V1",
  "description": "Single-project contract that makes research-loop objective, mutable surfaces, immutable authority references, gate seams, advancement, rollback, and stop semantics explicit without replacing the underlying workspace/task/event/checkpoint/handoff substrate.",
  "type": "object",
  "required": [
    "schema_version",
    "scope",
    "packet_id",
    "workspace_id",
    "objective",
    "mutable_surfaces",
    "immutable_authority_refs",
    "gate_conditions",
    "advancement",
    "rollback",
    "stop_conditions"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "scope": {
      "type": "string",
      "const": "single_project"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "mutable_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface_ref"
      }
    },
    "immutable_authority_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface_ref"
      }
    },
    "gate_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/gate_condition"
      }
    },
    "advancement": {
      "type": "object",
      "required": [
        "allowed_followups"
      ],
      "properties": {
        "allowed_followups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/task_transition"
          }
        }
      },
      "additionalProperties": false
    },
    "rollback": {
      "type": "object",
      "required": [
        "allowed_backtracks"
      ],
      "properties": {
        "allowed_backtracks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/task_transition"
          }
        }
      },
      "additionalProperties": false
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stop_condition"
      }
    }
  },
  "$defs": {
    "task_kind": {
      "type": "string",
      "enum": [
        "literature",
        "idea",
        "compute",
        "evidence_search",
        "finding",
        "draft_update",
        "review"
      ]
    },
    "task_status": {
      "type": "string",
      "enum": [
        "pending",
        "active",
        "completed",
        "blocked",
        "cancelled"
      ]
    },
    "handoff_kind": {
      "type": "string",
      "enum": [
        "compute",
        "feedback",
        "literature",
        "review",
        "writing"
      ]
    },
    "intervention_kind": {
      "type": "string",
      "enum": [
        "pause",
        "resume",
        "redirect",
        "inject_task",
        "approve",
        "cancel",
        "cascade_stop"
      ]
    },
    "surface_ref": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "ref_kind",
            "node_id"
          ],
          "properties": {
            "ref_kind": {
              "type": "string",
              "const": "workspace_node"
            },
            "node_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "ref_kind",
            "edge_id"
          ],
          "properties": {
            "ref_kind": {
              "type": "string",
              "const": "workspace_edge"
            },
            "edge_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "ref_kind",
            "task_kind"
          ],
          "properties": {
            "ref_kind": {
              "type": "string",
              "const": "task"
            },
            "task_kind": {
              "$ref": "#/$defs/task_kind"
            },
            "target_node_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "ref_kind",
            "handoff_kind"
          ],
          "properties": {
            "ref_kind": {
              "type": "string",
              "const": "handoff"
            },
            "handoff_kind": {
              "$ref": "#/$defs/handoff_kind"
            },
            "target_node_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "ref_kind",
            "artifact_ref"
          ],
          "properties": {
            "ref_kind": {
              "type": "string",
              "const": "artifact"
            },
            "artifact_ref": {
              "$ref": "https://nullius.dev/schemas/artifact_ref_v1.schema.json"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "task_transition": {
      "type": "object",
      "required": [
        "from_task_kind",
        "to_task_kind"
      ],
      "properties": {
        "from_task_kind": {
          "$ref": "#/$defs/task_kind"
        },
        "to_task_kind": {
          "$ref": "#/$defs/task_kind"
        }
      },
      "additionalProperties": false
    },
    "gate_condition": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "condition_kind",
            "task_kind",
            "allowed_statuses"
          ],
          "properties": {
            "condition_kind": {
              "type": "string",
              "const": "task_status"
            },
            "task_kind": {
              "$ref": "#/$defs/task_kind"
            },
            "allowed_statuses": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/task_status"
              }
            },
            "target_node_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "condition_kind",
            "handoff_kind"
          ],
          "properties": {
            "condition_kind": {
              "type": "string",
              "const": "handoff_registered"
            },
            "handoff_kind": {
              "$ref": "#/$defs/handoff_kind"
            },
            "target_node_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "condition_kind",
            "artifact_ref"
          ],
          "properties": {
            "condition_kind": {
              "type": "string",
              "const": "artifact_available"
            },
            "artifact_ref": {
              "$ref": "https://nullius.dev/schemas/artifact_ref_v1.schema.json"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "condition_kind"
          ],
          "properties": {
            "condition_kind": {
              "type": "string",
              "const": "checkpoint_available"
            },
            "checkpoint_label": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "stop_condition": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "condition_kind"
          ],
          "properties": {
            "condition_kind": {
              "type": "string",
              "const": "no_active_tasks"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "condition_kind",
            "task_kind",
            "terminal_statuses"
          ],
          "properties": {
            "condition_kind": {
              "type": "string",
              "const": "task_terminal"
            },
            "task_kind": {
              "$ref": "#/$defs/task_kind"
            },
            "terminal_statuses": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/task_status"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "condition_kind"
          ],
          "properties": {
            "condition_kind": {
              "type": "string",
              "const": "checkpoint_restored"
            },
            "checkpoint_label": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "condition_kind",
            "intervention_kind"
          ],
          "properties": {
            "condition_kind": {
              "type": "string",
              "const": "intervention"
            },
            "intervention_kind": {
              "$ref": "#/$defs/intervention_kind"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "condition_kind",
            "node_id"
          ],
          "properties": {
            "condition_kind": {
              "type": "string",
              "const": "decision_node"
            },
            "node_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
