{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nullius.dev/schemas/skill_proposal_v2.schema.json",
  "title": "SkillProposal V2",
  "description": "Skill proposal generated by EVO-12a Skill Genesis. Extends V1 with agent trace origin, evidence references, and generalization confidence.",
  "type": "object",
  "required": ["proposal_id", "proposal_type", "origin", "name", "description", "trigger", "action", "evidence_traces", "generalization_confidence", "gate_level", "status", "created_at"],
  "properties": {
    "proposal_id": {
      "type": "string",
      "pattern": "^sp_[0-9a-f-]+$",
      "description": "Unique proposal identifier (ID-01 compliant)"
    },
    "proposal_type": {
      "type": "string",
      "enum": ["new_skill", "scope_extension"],
      "description": "Whether this proposes a new skill or extends an existing one"
    },
    "origin": {
      "type": "string",
      "enum": ["manual", "agent_trace"],
      "description": "How this proposal was generated. 'agent_trace' = auto-detected by EVO-12a"
    },
    "name": {
      "type": "string",
      "maxLength": 100,
      "description": "Proposed skill name (kebab-case)"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Human-readable description of what the skill does"
    },
    "trigger": {
      "$ref": "#/$defs/SkillTrigger"
    },
    "action": {
      "$ref": "#/$defs/SkillAction"
    },
    "evidence_traces": {
      "type": "array",
      "items": { "$ref": "#/$defs/EvidenceTrace" },
      "minItems": 1,
      "description": "Concrete trace events that evidence this pattern. Must include ≥3 instances for agent_trace origin."
    },
    "generalization_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in the generalization from specific instances to reusable skill (0-1)"
    },
    "gate_level": {
      "type": "string",
      "enum": ["A0", "A1", "A2"],
      "description": "Required approval gate level. A0=auto, A1=light review, A2=full human review"
    },
    "status": {
      "type": "string",
      "enum": ["pending_review", "approved", "rejected", "installed", "retired"],
      "description": "Current proposal status"
    },
    "existing_skill_id": {
      "type": ["string", "null"],
      "description": "For scope_extension: the existing skill being extended. Must be non-null for scope_extension proposals (enforced via allOf discriminator)."
    },
    "existing_scope": {
      "type": "object",
      "description": "For scope_extension: the existing skill's current scope (from EVO-12 SkillScope). Required for scope_extension proposals."
    },
    "proposed_scope": {
      "type": "object",
      "description": "For scope_extension: the proposed merged scope after extension. Required for scope_extension proposals."
    },
    "new_cases": {
      "type": "array",
      "items": { "$ref": "#/$defs/EvidenceTrace" },
      "minItems": 1,
      "description": "For scope_extension: pattern occurrences not covered by the existing skill's scope."
    },
    "coverage_delta": {
      "$ref": "#/$defs/CoverageDelta"
    },
    "pattern_fingerprint": {
      "$ref": "#/$defs/PatternFingerprint"
    },
    "reviewer_notes": {
      "type": ["string", "null"],
      "description": "Notes from human reviewer"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "proposal_type": { "const": "scope_extension" } } },
      "then": {
        "required": ["existing_skill_id", "coverage_delta", "existing_scope", "proposed_scope", "new_cases"],
        "properties": {
          "existing_skill_id": { "type": "string" }
        }
      }
    },
    {
      "if": { "properties": { "origin": { "const": "agent_trace" } } },
      "then": { "properties": { "evidence_traces": { "minItems": 3 } } }
    }
  ],
  "$defs": {
    "SkillTrigger": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable trigger description"
        },
        "pattern_kind": {
          "type": "string",
          "enum": ["fix_pattern", "methodology_pattern", "package_usage_pattern"],
          "description": "What kind of repeatable pattern triggered this proposal."
        },
        "file_types": {
          "type": "array",
          "items": { "type": "string" },
          "description": "File extensions this skill applies to"
        },
        "tool_names": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tools that repeatedly appear in the triggering pattern."
        },
        "package_names": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Scientific or runtime packages that repeatedly appear in the triggering pattern."
        },
        "workflow_signature": {
          "type": "string",
          "description": "Normalized workflow or package signature for recurring process patterns."
        },
        "signal_pattern": {
          "type": "string",
          "description": "Signal pattern that activates this skill"
        }
      },
      "additionalProperties": false
    },
    "SkillAction": {
      "type": "object",
      "required": ["type", "rule"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["replace_regex", "insert_guard", "wrap_block", "reorder_lines", "add_annotation", "remove_pattern", "restructure", "workflow_recipe", "tool_sequence", "package_playbook"],
          "description": "Edit pattern class"
        },
        "rule": {
          "type": "string",
          "description": "Generalized rule definition"
        }
      },
      "additionalProperties": false
    },
    "EvidenceTrace": {
      "type": "object",
      "required": ["trace_id", "run_id", "file_path", "timestamp"],
      "properties": {
        "trace_id": {
          "type": "string",
          "format": "uuid"
        },
        "run_id": {
          "type": "string",
          "pattern": "^run_[0-9a-f-]+$"
        },
        "file_path": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "artifact_uri": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "H-18 ArtifactRef URI to the specific trace event content"
        }
      },
      "additionalProperties": false
    },
    "CoverageDelta": {
      "type": "object",
      "required": ["before", "after"],
      "properties": {
        "before": {
          "type": "string",
          "description": "Current coverage description"
        },
        "after": {
          "type": "string",
          "description": "Proposed coverage description"
        }
      },
      "additionalProperties": false
    },
    "PatternFingerprint": {
      "type": "object",
      "required": ["file_type", "edit_pattern", "context", "fingerprint_key"],
      "properties": {
        "file_type": {
          "type": "string",
          "description": "File extension pattern applies to"
        },
        "edit_pattern": {
          "type": "string",
          "enum": ["replace_regex", "insert_guard", "wrap_block", "reorder_lines", "add_annotation", "remove_pattern", "restructure"],
          "description": "Classified edit pattern type"
        },
        "context": {
          "type": "string",
          "description": "Contextual signal triggering the edit"
        },
        "fingerprint_key": {
          "type": "string",
          "description": "FNV-1a hash of (file_type|edit_pattern|context)"
        }
      },
      "additionalProperties": false
    }
  }
}
